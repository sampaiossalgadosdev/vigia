generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SUPERADMIN ───────────────────────────────────────────
model Superadmin {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── SUPERUSUÁRIO (dono de rede) ──────────────────────────
model Superusuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  redes     SuperusuarioTenant[]
  sugestoes Sugestao[]
}

model SuperusuarioTenant {
  id             String   @id @default(uuid())
  superusuarioId String
  tenantId       String
  criadoEm       DateTime @default(now())

  superusuario Superusuario @relation(fields: [superusuarioId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([superusuarioId, tenantId])
  @@index([superusuarioId])
  @@index([tenantId])
}

// ─── PLANO DO TENANT ──────────────────────────────────────
enum PlanoTenant {
  standard
  pro
}

// ─── TENANT ───────────────────────────────────────────────
model Tenant {
  id                     String      @id @default(uuid())
  nome                   String
  cnpj                   String      @unique
  email                  String
  telefone               String?
  uf                     String? // sigla (ex: SP) — vira cUFAutor nas consultas SEFAZ
  plano                  PlanoTenant @default(standard)
  regimeTributario       String      @default("simples")
  ativo                  Boolean     @default(true)
  ultimoCodigoReferencia Int         @default(0)
  // Certificado digital A1 do tenant, criptografado com AES-256-GCM
  // (chave em CERT_ENCRYPTION_KEY). Gerido só pelo Super Admin. É o MESMO
  // certificado usado tanto pra Distribuição DF-e/manifestação (NF-e de
  // entrada) quanto pra emissão de NFC-e própria (Reforma 2026) — uma
  // empresa tem um único A1 por CNPJ, reaproveitado aqui de propósito.
  certificadoPfx         Bytes?
  certificadoSenha       String?
  certificadoUploadEm    DateTime?
  certificadoValidade    DateTime? // data de expiração (extraída do certificado no upload, quando possível)
  // Configuração fiscal p/ emissão de NFC-e (Reforma 2026) — Fase 1a: só
  // armazenamento, sem cálculo/emissão ainda. CSCs são criptografados com o
  // mesmo mecanismo do certificado (certcrypto.js).
  cscProducao            String?
  cscProducaoId          String?
  cscHomologacao         String?
  cscHomologacaoId       String?
  cnae                   String?
  inscricaoEstadual      String?
  ambienteFiscal         String      @default("homologacao") // homologacao | producao (por tenant; distinto do env global SEFAZ_AMBIENTE usado na Distribuição DF-e)
  // Endereço do emitente — obrigatório pra montar o grupo enderEmit da
  // NFC-e (sem ele nenhuma nota é autorizada, nem em homologação). UF já
  // existe acima (campo `uf`), reaproveitado aqui, não duplicado.
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  municipio              String?
  codigoMunicipioIbge    String? // 7 dígitos, exigido pela SEFAZ no campo cMun
  cep                    String?
  // Cursor da Distribuição DF-e: último NSU já recebido da SEFAZ.
  ultimoNsu              String      @default("0")
  // Token do link público da tela Açougue TV (tv.html?token=...): liga a
  // televisão ao tenant sem login. Gerado/regenerado no painel Açougue TV.
  tvToken                String?     @unique
  criadoEm               DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  usuarios      Usuario[]
  perfis        Perfil[]
  produtos      Produto[]
  categorias    Categoria[]
  fornecedores  Fornecedor[]
  nfes          Nfe[]
  movimentacoes MovimentacaoEstoque[]
  sugestoes     Sugestao[]
  superusuarios SuperusuarioTenant[]
  auditoria     Auditoria[]
  refreshTokens RefreshToken[]
  decisoesIA    DecisaoIA[]
  vendas          Venda[]
  promocoes       Promocao[]
  caixas          Caixa[]
  nfeDistribuicao NfeDistribuicao[]
  depositos       Deposito[]
  inventarios     Inventario[]
  contasPagar     ContaPagar[]
  contasReceber   ContaReceber[]
}

// ─── REFRESH TOKEN ────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  tenantId  String?
  usuarioId String?
  token     String   @unique
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([token])
  @@index([usuarioId])
}

// ─── PERFIL (papel customizável por tenant) ──────────────
// "Dono" não é um Perfil: é um papel fixo (Usuario.isDono),
// criado junto com o tenant, com acesso total automático.
model Perfil {
  id           String   @id @default(uuid())
  tenantId     String
  nome         String
  descricao    String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  permissoes PermissaoPerfil[]
  usuarios   Usuario[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

enum ModuloSistema {
  dashboard
  produtos
  fornecedores
  estoque
  usuarios
  perfis
  vendas
  promocoes
  caixa
  relatorios
  ia
  financeiro
}

enum NivelPermissao {
  acesso_completo // GET, POST, PUT, DELETE
  edicao_leitura // GET, PUT
  somente_insercao // GET, POST
  somente_leitura // GET
  bloqueado // nenhum acesso — módulo nem aparece no menu
}

model PermissaoPerfil {
  id       String         @id @default(uuid())
  perfilId String
  modulo   ModuloSistema
  nivel    NivelPermissao @default(bloqueado)

  perfil Perfil @relation(fields: [perfilId], references: [id])

  @@unique([perfilId, modulo])
  @@index([perfilId])
}

// ─── USUÁRIO ──────────────────────────────────────────────
model Usuario {
  id        String   @id @default(uuid())
  tenantId  String
  nome      String
  email     String
  senha     String
  isDono    Boolean  @default(false) // acesso total, não usa Perfil
  perfilId  String? // obrigatório quando isDono = false
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  perfil Perfil? @relation(fields: [perfilId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([perfilId])
}

// ─── CATEGORIA ────────────────────────────────────────────
// Hierarquia de 2 níveis: Grupo (parentId null) → Subgrupo (parentId
// aponta pro grupo pai). Subgrupo de subgrupo não é permitido (regra
// no CategoriaService). markupPercent é o markup default aplicável aos
// produtos do escopo (ex: 35.00 = 35%).
model Categoria {
  id            String   @id @default(uuid())
  tenantId      String
  nome          String
  markupPercent Decimal? @db.Decimal(5, 2)
  parentId      String?
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  parent   Categoria?  @relation("CategoriaHierarquia", fields: [parentId], references: [id])
  filhos   Categoria[] @relation("CategoriaHierarquia")
  produtos Produto[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@index([parentId])
}

// ─── PRODUTO ──────────────────────────────────────────────
model Produto {
  id               String   @id @default(uuid())
  tenantId         String
  ean              String
  codigoReferencia String? // código sequencial por tenant, gerado automaticamente na criação
  plu              String? // código PLU para produtos por peso (balança)
  nome             String
  marca            String?
  ncm              String?
  unidade          String   @default("UN") // UN | KG | CX | L | PC | FD
  vendidoPorPeso   Boolean  @default(false)
  preco            Decimal  @db.Decimal(10, 2)
  precoDesejado    Decimal? @db.Decimal(10, 2) // preço que o gerente pretende praticar (não é o vigente)
  custoMedio       Decimal  @default(0) @db.Decimal(10, 2)
  cfop             String? // 4 dígitos, ex: 5102
  origem           String? // nacional | importado
  configTributaria String? // tributado_integral | substituicao_tributaria | isento | nao_tributado
  // Reforma Tributária 2026 (IBS/CBS) — nullable: produtos existentes ainda
  // não têm isso preenchido; a migração de dados fica pra outra etapa.
  cstIbsCbs        String? // classificador de situação tributária IBS/CBS
  cClassTrib       String? // classificador de tributação (código da Reforma)
  brstbs           String? // Nomenclatura Brasileira de Serviços — só quando o item for serviço
  estoqueQtd       Decimal  @default(0) @db.Decimal(10, 3)
  estoqueMin       Decimal  @default(0) @db.Decimal(10, 3)
  // Fase 2b: controle de lote/validade é OPCIONAL por produto — default
  // false preserva 100% do comportamento atual (só saldo agregado, sem
  // lote) pra todo produto existente. Mesmo padrão de permiteEstoqueNegativo
  // (Fase 2a): flag configurável, default não muda nada.
  controlaLote     Boolean  @default(false)
  imagemUrl        String?
  categoriaId      String?
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  categoria     Categoria?            @relation(fields: [categoriaId], references: [id])
  itensNfe      NfeItem[]
  movimentacoes MovimentacaoEstoque[]
  decisoesIA    DecisaoIA[]
  itensVenda    VendaItem[]
  promocoes     Promocao[]
  estoques      EstoqueProduto[]

  @@unique([tenantId, ean])
  @@unique([tenantId, codigoReferencia])
  @@index([tenantId])
  @@index([tenantId, ean])
  @@index([tenantId, categoriaId])
  @@index([tenantId, ativo])
  @@index([plu])
}

// ─── DEPÓSITO (Fase 2a — fundação de múltiplos depósitos) ─
// Todo tenant tem exatamente 1 depósito com principal=true (o "Depósito
// Principal", criado no backfill pra tenants existentes e sob demanda pra
// tenants novos — ver estoqueDeposito.repository.garantirDepositoPrincipal).
// Esta fase não implementa transferência entre depósitos nem UI pra
// escolher outro depósito na venda — todo fluxo hoje usa o principal.
model Deposito {
  id       String   @id @default(uuid())
  tenantId String
  nome     String
  principal Boolean @default(false) // exatamente 1 por tenant deve ser true
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  estoques EstoqueProduto[]
  movimentacoes MovimentacaoEstoque[]
  inventarios   Inventario[]

  @@index([tenantId])
}

// Saldo de um produto num depósito específico. Produto.estoqueQtd continua
// existindo como TOTAL AGREGADO (soma de EstoqueProduto de todos os
// depósitos daquele produto) — sincronizado pela camada de service
// (estoqueDeposito.repository.recalcularEstoqueAgregado), não por trigger.
model EstoqueProduto {
  id                     String   @id @default(uuid())
  produtoId              String
  depositoId             String
  quantidade             Decimal  @default(0) @db.Decimal(10, 3)
  // true preserva o comportamento ATUAL do sistema (estoque negativo
  // livre) — default seguro pra não quebrar nada na migração. Quem quiser
  // travar um produto específico contra estoque negativo muda isso pra
  // false depois, pelo cadastro do produto.
  permiteEstoqueNegativo Boolean  @default(true)

  produto  Produto  @relation(fields: [produtoId], references: [id])
  deposito Deposito @relation(fields: [depositoId], references: [id])
  lotes    Lote[]

  @@unique([produtoId, depositoId])
}

// Lote/validade dentro de um EstoqueProduto (Fase 2b) — só existe pra
// produtos com controlaLote=true. Cada entrada de estoque (NF-e) de um
// produto assim vira uma linha de Lote própria (nunca mescla com outro
// lote, mesmo que a validade seja igual), pra manter o consumo FIFO e o
// histórico de vencimento precisos.
model Lote {
  id               String   @id @default(uuid())
  estoqueProdutoId String
  numeroLote       String? // opcional, nem todo fornecedor informa
  dataValidade     DateTime
  quantidade       Decimal  @db.Decimal(10, 3)
  // false quando quantidade chega a zero, pra não sumir do histórico mas
  // parar de aparecer nas consultas de "lotes disponíveis" (FIFO/alertas).
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now())

  estoqueProduto EstoqueProduto @relation(fields: [estoqueProdutoId], references: [id])
  consumos       VendaItemLote[]
  movimentacoes  MovimentacaoEstoque[]

  @@index([estoqueProdutoId])
  @@index([estoqueProdutoId, ativo, dataValidade])
}

// ─── FORNECEDOR ───────────────────────────────────────────
model Fornecedor {
  id       String  @id @default(uuid())
  tenantId String
  nome     String
  // CNPJ (14 dígitos) quando pessoa_juridica; CPF (11) quando pessoa_fisica
  cnpj     String
  tipo     String  @default("pessoa_juridica") // pessoa_juridica | pessoa_fisica
  email    String?
  telefone String?
  celular  String?
  observacao String? @db.Text

  // Tributário
  contribuinteIcms String? // contribuinte | nao_contribuinte
  regimeTributario String? // simples | presumido | real (mesmos valores do Tenant)

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?

  // Integração Contas a Pagar (módulo financeiro ainda não existe —
  // captura de dado em texto para uso futuro)
  finCategoria     String?
  finTipoDocumento String?
  finConta         String?
  finCentroCusto   String?

  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant                    @relation(fields: [tenantId], references: [id])
  nfes           Nfe[]
  representantes FornecedorRepresentante[]
  contasPagar    ContaPagar[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

// Representantes comerciais do fornecedor (1:N)
model FornecedorRepresentante {
  id           String   @id @default(uuid())
  fornecedorId String
  nome         String
  email        String?
  telefone     String?
  celular      String?
  criadoEm     DateTime @default(now())

  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id])

  @@index([fornecedorId])
}

// Cache das consultas ao CNPJ.ws (limite público de 3 req/min):
// mesma consulta dentro de 30 dias sai daqui sem chamar a API.
model CnpjConsultaCache {
  id           String   @id @default(uuid())
  cnpj         String   @unique
  resposta     Json
  consultadoEm DateTime @default(now())
}

// ─── NF-e ENTRADA ─────────────────────────────────────────
model Nfe {
  id           String   @id @default(uuid())
  tenantId     String
  fornecedorId String?
  chaveAcesso  String   @unique
  numeroNfe    String
  dataEmissao  DateTime
  valorTotal   Decimal  @db.Decimal(10, 2)
  xmlOriginal  String   @db.Text
  status       String   @default("pendente") // pendente | confirmada | cancelada
  criadoEm     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id])
  itens      NfeItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([chaveAcesso])
}

model NfeItem {
  id             String   @id @default(uuid())
  nfeId          String
  produtoId      String?
  ean            String
  descricao      String
  ncm            String?
  unidade        String
  quantidade     Decimal  @db.Decimal(10, 3)
  valorUnitario  Decimal  @db.Decimal(10, 4)
  valorTotal     Decimal  @db.Decimal(10, 2)
  // Fator de conversão unidade da nota → unidade do sistema, definido no
  // matching manual. Quantidade que entra no estoque = quantidade × fator.
  fatorConversao Decimal? @db.Decimal(10, 4)
  status         String   @default("ok") // ok | pendente (produto não encontrado, aguarda confirmação)

  nfe     Nfe      @relation(fields: [nfeId], references: [id])
  produto Produto? @relation(fields: [produtoId], references: [id])

  @@index([nfeId])
  @@index([produtoId])
}

// ─── DISTRIBUIÇÃO DF-e (resumos recebidos da SEFAZ) ───────
// A SEFAZ entrega cada documento uma única vez, por NSU sequencial.
// Os resumos ficam persistidos aqui e a tela de consulta filtra
// (período/manifestação) sobre esta base local; Tenant.ultimoNsu guarda
// o cursor pra buscar só o que há de novo.
model NfeDistribuicao {
  id           String    @id @default(uuid())
  tenantId     String
  nsu          String
  chaveAcesso  String
  cnpjEmitente String?
  nomeEmitente String?
  dataEmissao  DateTime?
  valorTotal   Decimal?  @db.Decimal(10, 2)
  serie        String? // extraída da chave de acesso (posições 23-25)
  numero       String? // extraído da chave de acesso (posições 26-34)
  situacao     String? // cSitNFe: 1 autorizada | 2 cancelada | 3 denegada
  manifestacao String    @default("nao_manifestada") // nao_manifestada | ciencia | confirmada | desconhecida | nao_realizada
  natureza     String? // natOp — disponível só após baixar o XML completo
  xmlCompleto  String?   @db.Text // procNFe, quando já entregue/baixado
  importada    Boolean   @default(false) // já entrou no pipeline de Nfe/NfeItem?
  criadoEm     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, chaveAcesso])
  @@index([tenantId])
  @@index([tenantId, dataEmissao])
  @@index([tenantId, importada])
}

// ─── MOVIMENTAÇÃO DE ESTOQUE ──────────────────────────────
model MovimentacaoEstoque {
  id         String   @id @default(uuid())
  tenantId   String
  produtoId  String
  tipo       String // entrada | saida | ajuste | perda | devolucao | transferencia
  quantidade Decimal  @db.Decimal(10, 3)
  custoUnit  Decimal? @db.Decimal(10, 4)
  origem     String // nfe | venda | ajuste_manual | inventario | perda_manual | devolucao
  origemId   String?
  usuarioId  String?
  observacao String? // reaproveitado como "motivo" no ajuste manual (Fase 2c) — não duplica campo
  criadoEm   DateTime @default(now())
  // Fase 2c — só preenchidos para tipo='ajuste' (nulos em entrada/saida/
  // devolucao, que já tinham seu próprio jeito de calcular a quantidade
  // sem precisar do antes/depois explícito). Nullable: aditivo, não afeta
  // nenhuma movimentação já existente.
  quantidadeAnterior Decimal? @db.Decimal(10, 3)
  quantidadeNova     Decimal? @db.Decimal(10, 3)
  depositoId         String? // em qual depósito o ajuste ocorreu
  loteId             String? // qual lote específico foi corrigido, se o produto controla lote

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  produto  Produto   @relation(fields: [produtoId], references: [id])
  deposito Deposito? @relation(fields: [depositoId], references: [id])
  lote     Lote?     @relation(fields: [loteId], references: [id])

  @@index([tenantId])
  @@index([tenantId, produtoId])
  @@index([tenantId, tipo])
  @@index([criadoEm])
}

// ─── INVENTÁRIO (Fase 2c) ─────────────────────────────────
// Contagem física (geral: todo o depósito; parcial: uma categoria) que
// reconcilia com o sistema via ajusteEstoque no fechamento.
model Inventario {
  id              String    @id @default(uuid())
  tenantId        String
  depositoId      String
  tipo            String // geral | parcial
  categoriaFiltro String? // usado só quando tipo = parcial
  status          String    @default("aberto") // aberto | fechado
  iniciadoPorId   String
  iniciadoEm      DateTime  @default(now())
  finalizadoEm    DateTime?

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  deposito Deposito         @relation(fields: [depositoId], references: [id])
  itens    InventarioItem[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model InventarioItem {
  id                String    @id @default(uuid())
  inventarioId      String
  produtoId         String
  quantidadeSistema Decimal   @db.Decimal(10, 3) // snapshot no início
  quantidadeContada Decimal?  @db.Decimal(10, 3) // preenchido durante a contagem
  contadoPorId      String?
  contadoEm         DateTime?

  inventario Inventario @relation(fields: [inventarioId], references: [id])

  @@index([inventarioId])
  @@index([produtoId])
}

// ─── SUGESTÃO (superusuário → tenant) ────────────────────
model Sugestao {
  id             String   @id @default(uuid())
  superusuarioId String
  tenantId       String
  titulo         String
  mensagem       String   @db.Text
  tipo           String // promocao | estoque | preco | geral
  status         String   @default("pendente") // pendente | lida | arquivada
  criadoEm       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  superusuario Superusuario @relation(fields: [superusuarioId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([superusuarioId])
}

// ─── AUDITORIA ────────────────────────────────────────────
model Auditoria {
  id         String   @id @default(uuid())
  tenantId   String?
  usuarioId  String?
  acao       String // login | logout | criar | editar | excluir | importar | etc.
  entidade   String // Produto | Fornecedor | Usuario | Nfe | Promocao | etc.
  entidadeId String?
  antes      Json?
  depois     Json?
  ip         String?
  criadoEm   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entidade])
  @@index([criadoEm])
}

// ─── DECISÃO IA ───────────────────────────────────────────
model DecisaoIA {
  id                   String   @id @default(uuid())
  tenantId             String
  produtoId            String
  tipo                 String // promocao_criada | markup_alterado | preco_alterado
  valorAntes           Decimal? @db.Decimal(10, 2)
  valorDepois          Decimal  @db.Decimal(10, 2)
  estoqueNaMomento     Decimal  @db.Decimal(10, 3)
  giro30dias           Decimal  @default(0) @db.Decimal(10, 3)
  resultadoMargem      Decimal? @db.Decimal(10, 2)
  resultadoVolumeExtra Decimal? @db.Decimal(10, 3)
  criadoEm             DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  @@index([tenantId])
  @@index([tenantId, produtoId])
}

// ─── VENDA ────────────────────────────────────────────────
model Venda {
  id                 String    @id @default(uuid())
  tenantId           String
  operadorId         String?
  total              Decimal   @db.Decimal(10, 2)
  subtotal           Decimal   @db.Decimal(10, 2)
  desconto           Decimal   @default(0) @db.Decimal(10, 2)
  troco              Decimal   @default(0) @db.Decimal(10, 2)
  cpfConsumidor      String?
  chaveNfce          String? // chave de acesso REAL de 44 dígitos após autorização da SEFAZ (Fase 1c) — antes disso, só o localId do PDV
  status             String    @default("concluida") // concluida | cancelada | pendente_sync
  canceladoEm        DateTime?
  canceladoPor       String?
  motivoCancelamento String?
  // Emissão fiscal da NFC-e (Fase 1c) — preenchidos por nfceEmissao.service.
  emitidoEm              DateTime? // momento da autorização (não confundir com criadoEm, que é o momento da venda)
  emitidoViaContingencia Boolean   @default(false) // true quando autorizado via SVC (SEFAZ do estado estava fora do ar)
  protocoloAutorizacao   String?
  // XML gerado na tentativa de emissão (Fase 1c complemento) — salvo mesmo
  // quando a SEFAZ rejeita (cStat != 100): é o registro do que foi de fato
  // tentado enviar, não só do que foi aceito. Sem campo equivalente pro
  // cancelamento por ora — ver justificativa no service (nem o mock nem o
  // caminho real de cancelamento produzem hoje uma string de XML própria
  // pro nosso código guardar.
  xmlNfce                String?   @db.Text
  protocoloCancelamento  String?
  criadoEm           DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  itens         VendaItem[]
  pagamentos    VendaPagamento[]
  contasReceber ContaReceber[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, criadoEm])
  @@index([operadorId])
}

model VendaItem {
  id            String  @id @default(uuid())
  vendaId       String
  produtoId     String
  quantidade    Decimal @db.Decimal(10, 3)
  precoUnitario Decimal @db.Decimal(10, 2)
  custoUnitario Decimal @db.Decimal(10, 2)
  desconto      Decimal @default(0) @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)
  total         Decimal @db.Decimal(10, 2)
  promocaoId    String?
  // Reforma Tributária 2026 (IBS/CBS) — snapshot do que foi calculado NESTA
  // venda: se a alíquota/classificação do produto mudar depois, a venda
  // antiga continua mostrando o valor de fato aplicado no momento da venda.
  valorIbs           Decimal? @db.Decimal(10, 2)
  valorCbs           Decimal? @db.Decimal(10, 2)
  cstIbsCbsAplicado  String?
  cClassTribAplicado String?

  venda    Venda     @relation(fields: [vendaId], references: [id])
  produto  Produto   @relation(fields: [produtoId], references: [id])
  promocao Promocao? @relation(fields: [promocaoId], references: [id])
  lotesConsumidos VendaItemLote[]

  @@index([vendaId])
  @@index([produtoId])
}

// Rastreio de quais Lote(s) cada VendaItem consumiu (Fase 2b complemento) —
// só existe para produtos com controlaLote=true. Tabela separada (não um
// loteId único em VendaItem) porque o consumo FIFO pode "espirrar" por mais
// de um lote numa única venda; precisamos do histórico completo pra
// devolver certo no cancelamento.
model VendaItemLote {
  id          String  @id @default(uuid())
  vendaItemId String
  loteId      String
  quantidade  Decimal @db.Decimal(10, 3) // consumido DESTE lote, para este item

  vendaItem VendaItem @relation(fields: [vendaItemId], references: [id])
  lote      Lote      @relation(fields: [loteId], references: [id])

  @@index([vendaItemId])
  @@index([loteId])
}

model VendaPagamento {
  id      String  @id @default(uuid())
  vendaId String
  forma   String // dinheiro | credito | debito | pix | voucher | outros
  valor   Decimal @db.Decimal(10, 2)
  // Placeholder de schema pro futuro Split Payment da Reforma — nenhuma
  // lógica de segregação real ainda, só o campo existindo pra não travar depois.
  valorTributoSegregado Decimal? @default(0) @db.Decimal(10, 2)

  venda Venda @relation(fields: [vendaId], references: [id])

  @@index([vendaId])
}

// ─── PROMOÇÃO ─────────────────────────────────────────────
model Promocao {
  id         String   @id @default(uuid())
  tenantId   String
  produtoId  String
  nome       String
  tipo       String // percentual | valor_fixo | leve_pague
  desconto   Decimal  @db.Decimal(10, 2)
  leveQtd    Int?
  pagueQtd   Int?
  dataInicio DateTime
  dataFim    DateTime
  ativa      Boolean  @default(true)
  criadoEm   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  produto    Produto     @relation(fields: [produtoId], references: [id])
  itensVenda VendaItem[]

  @@index([tenantId])
  @@index([tenantId, produtoId, ativa])
  @@index([tenantId, dataFim])
}

// ─── CAIXA (fechamento diário) ────────────────────────────
model Caixa {
  id              String    @id @default(uuid())
  tenantId        String
  operadorId      String?
  abertoEm        DateTime  @default(now())
  fechadoEm       DateTime?
  valorAbertura   Decimal   @db.Decimal(10, 2)
  valorFechamento Decimal?  @db.Decimal(10, 2)
  totalVendas     Decimal   @default(0) @db.Decimal(10, 2)
  totalDinheiro   Decimal   @default(0) @db.Decimal(10, 2)
  totalCartao     Decimal   @default(0) @db.Decimal(10, 2)
  totalPix        Decimal   @default(0) @db.Decimal(10, 2)
  diferenca       Decimal?  @db.Decimal(10, 2)
  status          String    @default("aberto") // aberto | fechado
  observacao      String?
  updatedAt       DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  sangrias Sangria[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Sangria {
  id         String   @id @default(uuid())
  caixaId    String
  tenantId   String
  tipo       String // sangria | suprimento
  valor      Decimal  @db.Decimal(10, 2)
  motivo     String?
  operadorId String?
  criadoEm   DateTime @default(now())

  caixa Caixa @relation(fields: [caixaId], references: [id])

  @@index([caixaId])
  @@index([tenantId])
}

// ─── FINANCEIRO (Fase 4a — fundação) ──────────────────────
model ContaPagar {
  id             String    @id @default(uuid())
  tenantId       String
  fornecedorId   String? // opcional — nem toda despesa tem fornecedor cadastrado (ex: aluguel, água)
  descricao      String
  valor          Decimal   @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String    @default("aberto") // aberto | pago | cancelado
  formaPagamento String? // preenchido só na baixa
  observacao     String?
  criadoPorId    String
  criadoEm       DateTime  @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dataVencimento])
}

model ContaReceber {
  id               String    @id @default(uuid())
  tenantId         String
  vendaId          String? // opcional — vínculo com uma venda (ex: recebível de cartão que ainda não caiu), null para recebíveis manuais/avulsos
  descricao        String
  valor            Decimal   @db.Decimal(10, 2)
  dataVencimento   DateTime
  dataRecebimento  DateTime?
  status           String    @default("aberto") // aberto | recebido | cancelado
  formaRecebimento String?
  observacao       String?
  criadoPorId      String
  criadoEm         DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  venda  Venda? @relation(fields: [vendaId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dataVencimento])
}
